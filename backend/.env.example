# Ejemplo de configuración - copia esto a .env y actualiza los valores

# JWT Configuration (genera con: openssl rand -base64 48)
APP_JWT_SECRET=GENERA_UN_SECRET_ALEATORIO_AQUI_64_CARACTERES
APP_JWT_EXPIRATION_MS=3600000
APP_JWT_REFRESH_EXPIRATION_MS=604800000
APP_FRONTEND_BASE_URL=https://naval-go.com

# PostgreSQL Database (DigitalOcean Managed)
SPRING_DATASOURCE_URL=jdbc:postgresql://private-navalgo-db-do-user-33837097-0.h.db.ondigitalocean.com:25060/defaultdb?sslmode=require
SPRING_DATASOURCE_USERNAME=doadmin
SPRING_DATASOURCE_PASSWORD=TU_PASSWORD_REAL_AQUI

# CORS y cookies (produccion HTTPS)
APP_SECURITY_CORS_ALLOWED_ORIGINS=https://naval-go.com,https://www.naval-go.com
APP_SECURITY_COOKIE_REFRESH_NAME=navalgo_refresh_token
APP_SECURITY_COOKIE_SAME_SITE=None
APP_SECURITY_COOKIE_SECURE=true
APP_SECURITY_COOKIE_PATH=/api/auth

# Exponer backend solo en localhost y dejar Nginx como entrada publica.
# Usa 0.0.0.0 solo si necesitas acceso directo por IP:puerto.
BACKEND_BIND_ADDRESS=127.0.0.1

# DigitalOcean Spaces (S3)
APP_MEDIA_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
APP_MEDIA_SPACES_REGION=fra1
APP_MEDIA_SPACES_BUCKET=navalgo-storage
APP_MEDIA_SPACES_ACCESS_KEY=TU_SPACES_ACCESS_KEY
APP_MEDIA_SPACES_SECRET_KEY=TU_SPACES_SECRET_KEY
APP_MEDIA_PUBLIC_BASE_URL=https://navalgo-storage.fra1.digitaloceanspaces.com

# Limites de media
APP_MEDIA_MAX_IMAGE_SIZE_BYTES=10485760
APP_MEDIA_MAX_VIDEO_SIZE_BYTES=26214400
APP_MEDIA_MAX_SIGNATURE_SIZE_BYTES=5242880
APP_MEDIA_MAX_PROFILE_PHOTO_SIZE_BYTES=5242880

# Firebase Admin SDK para push
APP_FIREBASE_ENABLED=true
APP_FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-admin.json
APP_FIREBASE_SERVICE_ACCOUNT_HOST_PATH=./secrets/firebase-admin.json

# Invitaciones de registro
APP_AUTH_REGISTRATION_INVITATION_TTL_HOURS=72

# Email transaccional con Resend
APP_EMAIL_ENABLED=true
APP_EMAIL_FROM=Naval-GO <no-reply@naval-go.com>
APP_EMAIL_REPLY_TO=soporte@naval-go.com
APP_EMAIL_RESEND_API_KEY=re_TU_API_KEY_AQUI
APP_EMAIL_RESEND_API_URL=https://api.resend.com/emails

# WhatsApp Cloud API
APP_WHATSAPP_ENABLED=false
APP_WHATSAPP_VERIFY_TOKEN=TU_VERIFY_TOKEN
APP_WHATSAPP_API_TOKEN=TU_ACCESS_TOKEN_DE_META
APP_WHATSAPP_PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID
APP_WHATSAPP_API_VERSION=v20.0
APP_WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
